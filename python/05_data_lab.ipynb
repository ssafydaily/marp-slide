   "source": [
    "def count_character(words, target):\n",
    "  count = 0\n",
    "  for char in words:\n",
    "    if target == char:\n",
    "      count += 1\n",
    "\n",
    "  return count\n",
    "\n",
    "print(count_character(\"Hello, World!\", \"o\"))"
   ]
  },
